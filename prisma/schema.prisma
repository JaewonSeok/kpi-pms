  retryCount      Int                         @default(0)
  maxRetries      Int                         @default(3)
  nextRetryAt     DateTime?
  lastError       String?
  digestKey       String?
  isDigestMember  Boolean                     @default(false)
  sourceType      String?
  sourceId        String?
  idempotencyKey  String                      @unique
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  attempts        NotificationAttempt[]
  deadLetter      NotificationDeadLetter?

  @@index([status, availableAt])
  @@index([recipientId, channel, scheduledFor])
  @@index([digestKey])
  @@map("notification_jobs")
}

model NotificationAttempt {
  id                String                    @id @default(cuid())
  notificationJobId String
  notificationJob   NotificationJob           @relation(fields: [notificationJobId], references: [id], onDelete: Cascade)
  channel           NotificationDeliveryChannel
  status            NotificationAttemptStatus
  responseCode      String?
  providerMessageId String?
  errorMessage      String?
  attemptedAt       DateTime                  @default(now())

  @@index([notificationJobId, attemptedAt])
  @@map("notification_attempts")
}

model NotificationDeadLetter {
  id               String                    @id @default(cuid())
  notificationJobId String                   @unique
  notificationJob  NotificationJob           @relation(fields: [notificationJobId], references: [id], onDelete: Cascade)
  recipientId      String
  recipient        Employee                  @relation(fields: [recipientId], references: [id])
  channel          NotificationDeliveryChannel
  type             NotificationType
  idempotencyKey   String
  reason           String
  payload          Json?
  createdAt        DateTime                  @default(now())

  @@index([recipientId, createdAt])
  @@map("notification_dead_letters")
}

model JobExecution {
  id              String             @id @default(cuid())
  jobName         String
  jobType         JobExecutionType
  status          JobExecutionStatus @default(RUNNING)
  triggerSource   String?
  startedAt       DateTime           @default(now())
  finishedAt      DateTime?
  processedCount  Int                @default(0)
  successCount    Int                @default(0)
  failedCount     Int                @default(0)
  retriedCount    Int                @default(0)
  deadLetterCount Int                @default(0)
  suppressedCount Int                @default(0)
  metadata        Json?
  errorMessage    String?

  @@index([jobType, startedAt])
  @@map("job_executions")
}

model AiRequestLog {
  id               String           @id @default(cuid())
  requesterId      String
  requester        Employee         @relation(fields: [requesterId], references: [id])
  requestType      AIRequestType
  requestStatus    AIRequestStatus  @default(PENDING)
  approvalStatus   AIApprovalStatus @default(PENDING)
  sourceType       String?
  sourceId         String?
  provider         String           @default("OPENAI")
  model            String?
  requestPayload   Json?
  responsePayload  Json?
  approvedPayload  Json?
  piiMinimized     Boolean          @default(true)
  inputTokens      Int?
  outputTokens     Int?
  estimatedCostUsd Float            @default(0)
  errorCode        String?
  errorMessage     String?
  approvedById     String?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([requesterId, createdAt])
  @@index([requestType, createdAt])
  @@map("ai_request_logs")
}

model OperationalEvent {
  id        String                @id @default(cuid())
  level     OperationalEventLevel
  component String
  eventType String
  message   String
  metadata  Json?
  createdAt DateTime              @default(now())

  @@index([level, createdAt])
  @@index([component, createdAt])
  @@map("operational_events")
}

enum NotificationType {
  KPI_DEADLINE
  GOAL_REMINDER
  CHECKPOINT_REMINDER
  EVALUATION_REMINDER
  CALIBRATION_REMINDER
  RESULT_CONFIRMATION_REMINDER
  MEETING_REMINDER
  MONTHLY_REMINDER
  EVAL_START
  EVAL_RECEIVED
  EVAL_REJECTED
  EVAL_COMPLETED
  RESULT_PUBLISHED
  CHECKIN_REMINDER
  CHECKIN_SCHEDULED
  FEEDBACK_REQUEST
  FEEDBACK_DEADLINE
  ACTION_ITEM_DUE
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  BOTH
}

enum NotificationDeliveryChannel {
  IN_APP
  EMAIL
}

enum NotificationJobStatus {
  QUEUED
  PROCESSING
  SENT
  RETRY_PENDING
  SUPPRESSED
  DEAD_LETTER
}

enum NotificationAttemptStatus {
  SUCCESS
  FAILED
  SUPPRESSED
}

enum JobExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

enum JobExecutionType {
  SCHEDULER
  DISPATCH
  RETRY
  DIGEST
  DEAD_LETTER_SWEEP
}

enum AIRequestType {
  KPI_ASSIST
  EVAL_PERFORMANCE_BRIEFING
  EVAL_COMMENT_DRAFT
  BIAS_ANALYSIS
  GROWTH_PLAN
}

enum AIRequestStatus {
  PENDING
  SUCCESS
  FALLBACK
  DISABLED
  FAILED
}

enum AIApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OperationalEventLevel {
  INFO
  WARN
  ERROR
}

// ============================================
// 9. 감사 로그
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId, timestamp])
  @@map("audit_logs")
}

// ============================================
// 10. 이의신청
// ============================================

model ImpersonationSession {
  id                  String   @id @default(cuid())
  impersonatorAdminId String
  impersonatedUserId  String
  reason              String
  startedAt           DateTime @default(now())
  expiresAt           DateTime
  endedAt             DateTime?
  isActive            Boolean  @default(true)
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([impersonatorAdminId, startedAt])
  @@index([impersonatedUserId, startedAt])
  @@index([isActive, expiresAt])
  @@map("impersonation_sessions")
}

model Appeal {
  id            String       @id @default(cuid())
  evaluationId  String
  evaluation    Evaluation   @relation(fields: [evaluationId], references: [id])
  appealerId    String
  appealer      Employee     @relation(fields: [appealerId], references: [id])
  reason        String
  status        AppealStatus @default(SUBMITTED)
  adminResponse String?
  resolvedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("appeals")
}

enum AppealStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  CLOSED
}

// ============================================
// 11. 업로드 이력
// ============================================

model UploadHistory {
  id           String   @id @default(cuid())
  uploadType   String
  uploaderId   String
  fileName     String
  totalRows    Int
  successCount Int
  failCount    Int
  errorDetails Json?
  uploadedAt   DateTime @default(now())

  @@map("upload_histories")
}

// ============================================
// 12. NextAuth 세션 관리
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
