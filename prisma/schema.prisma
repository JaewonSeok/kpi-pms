generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 1. 조직/인사 도메인
// ============================================

model Organization {
  id            String         @id @default(cuid())
  name          String
  fiscalYear    Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  departments   Department[]
  evalCycles    EvalCycle[]
  gradeSettings GradeSetting[]
  compensationRuleSets CompensationRuleSet[]
  feedbackFolders FeedbackFolder[]
  feedbackAdminGroups FeedbackAdminGroup[]
  upwardReviewTemplates UpwardReviewTemplate[]
  aiCompetencyExternalCertMasters AiCompetencyExternalCertMaster[]
  wordCloud360Keywords WordCloud360Keyword[]
  wordCloud360Cycles   WordCloud360Cycle[]

  @@map("organizations")
}

model Department {
  id           String       @id @default(cuid())
  deptCode     String       @unique
  deptName     String
  parentDeptId String?
  parentDept   Department?  @relation("DeptHierarchy", fields: [parentDeptId], references: [id])
  childDepts   Department[] @relation("DeptHierarchy")
  leaderEmployeeId String?
  leaderEmployee   Employee?  @relation("DepartmentLeader", fields: [leaderEmployeeId], references: [id], onDelete: SetNull)
  excludeLeaderFromEvaluatorAutoAssign Boolean @default(false)
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])
  employees    Employee[]
  orgKpis      OrgKpi[]
  businessPlans BusinessPlanDocument[]
  jobDescriptions JobDescriptionDocument[]
  teamKpiRecommendationSourceSets TeamKpiRecommendationSet[] @relation("TeamKpiRecommendationSourceDepartment")
  teamKpiRecommendationTargetSets TeamKpiRecommendationSet[] @relation("TeamKpiRecommendationTargetDepartment")
  teamKpiReviewSourceRuns TeamKpiReviewRun[] @relation("TeamKpiReviewSourceDepartment")
  teamKpiReviewTargetRuns TeamKpiReviewRun[] @relation("TeamKpiReviewTargetDepartment")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("departments")
}

model Employee {
  id              String         @id @default(cuid())
  empId           String         @unique
  empName         String
  gwsEmail        String         @unique
  position        Position
  role            SystemRole
  deptId          String
  department      Department     @relation(fields: [deptId], references: [id])
  jobTitle        String?
  teamName        String?
  managerId       String?
  teamLeaderId    String?
  sectionChiefId  String?
  divisionHeadId  String?
  joinDate        DateTime
  resignationDate DateTime?
  sortOrder       Int?
  notes           String?
  masterLoginPermissionGranted Boolean      @default(false)
  currentSalary   Float          @default(0)
  status          EmployeeStatus @default(ACTIVE)
  profileImageUrl String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  ledDepartments    Department[] @relation("DepartmentLeader")
  personalKpis      PersonalKpi[]
  monthlyRecords    MonthlyRecord[]
  selfEvaluations   Evaluation[]    @relation("EvalTarget")
  givenEvaluations  Evaluation[]    @relation("Evaluator")
  performanceAssignmentsAsTarget    EvaluationAssignment[] @relation("PerformanceEvaluationAssignmentTarget")
  performanceAssignmentsAsEvaluator EvaluationAssignment[] @relation("PerformanceEvaluationAssignmentEvaluator")
  createdPerformanceAssignments     EvaluationAssignment[] @relation("PerformanceEvaluationAssignmentCreatedBy")
  updatedPerformanceAssignments     EvaluationAssignment[] @relation("PerformanceEvaluationAssignmentUpdatedBy")
  checkInsAsOwner   CheckIn[]       @relation("CheckInOwner")
  checkInsAsManager CheckIn[]       @relation("CheckInManager")
  feedbackGiven     MultiFeedback[] @relation("FeedbackGiver")
  feedbackReceived  MultiFeedback[] @relation("FeedbackReceiver")
  feedbackNominationTargets     FeedbackNomination[] @relation("FeedbackNominationTarget")
  feedbackNominationReviewers   FeedbackNomination[] @relation("FeedbackNominationReviewer")
  feedbackNominationSubmitters  FeedbackNomination[] @relation("FeedbackNominationSubmitter")
  feedbackNominationApprovers   FeedbackNomination[] @relation("FeedbackNominationApprover")
  feedbackReportTargets         FeedbackReportCache[] @relation("FeedbackReportTarget")
  feedbackReportGenerators      FeedbackReportCache[] @relation("FeedbackReportGenerator")
  feedbackAdminGroupMemberships FeedbackAdminGroupMember[]
  feedbackRoundCollaborations   FeedbackRoundCollaborator[]
  onboardingReviewGenerations   OnboardingReviewGeneration[]
  developmentPlans              DevelopmentPlan[] @relation("DevelopmentPlanEmployee")
  createdDevelopmentPlans       DevelopmentPlan[] @relation("DevelopmentPlanCreator")
  notifications     Notification[]
  appeals           Appeal[]
  compensationSnapshots CompensationScenarioEmployee[]
  notificationPreference NotificationPreference?
  notificationJobs  NotificationJob[]
  notificationDeadLetters NotificationDeadLetter[]
  aiRequestLogs     AiRequestLog[]
  aiCompetencyAssignments AiCompetencyAssignment[]
  aiCompetencyGateAssignments AiCompetencyGateAssignment[]
  aiCompetencyAttempts AiCompetencyAttempt[]
  aiCompetencyGeneratedExamSets AiCompetencyGeneratedExamSet[]
  aiCompetencyAnswerReviews AiCompetencyAnswer[] @relation("AiCompetencyAnswerReviewer")
  aiCompetencySecondRoundSubmissions AiCompetencySecondRoundSubmission[]
  aiCompetencySubmissionReviews AiCompetencySubmissionReview[] @relation("AiCompetencySubmissionReviewer")
  aiCompetencySubmissionDecisions AiCompetencySecondRoundSubmission[] @relation("AiCompetencySubmissionDecisionActor")
  aiCompetencyExternalCertClaims AiCompetencyExternalCertClaim[]
  aiCompetencyExternalCertApprovals AiCompetencyExternalCertClaim[] @relation("AiCompetencyCertApprover")
  aiCompetencyResults AiCompetencyResult[] @relation("AiCompetencyResultEmployee")
  aiCompetencyResultSyncs AiCompetencyResult[] @relation("AiCompetencyResultSyncActor")
  wordCloud360EvaluatorAssignments WordCloud360Assignment[] @relation("WordCloud360Evaluator")
  wordCloud360EvaluateeAssignments WordCloud360Assignment[] @relation("WordCloud360Evaluatee")
  wordCloud360EvaluatorResponses   WordCloud360Response[] @relation("WordCloud360ResponseEvaluator")
  wordCloud360EvaluateeResponses   WordCloud360Response[] @relation("WordCloud360ResponseEvaluatee")

  @@map("employees")
}

enum Position {
  MEMBER
  TEAM_LEADER
  SECTION_CHIEF
  DIV_HEAD
  CEO
}

enum SystemRole {
  ROLE_MEMBER
  ROLE_TEAM_LEADER
  ROLE_SECTION_CHIEF
  ROLE_DIV_HEAD
  ROLE_CEO
  ROLE_ADMIN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  RESIGNED
}

// ============================================
// 2. 평가 등급 설정
// ============================================

model GradeSetting {
  id             String       @id @default(cuid())
  orgId          String
  organization   Organization @relation(fields: [orgId], references: [id])
  evalYear       Int
  gradeOrder     Int
  gradeName      String
  baseScore      Int
  minScore       Int
  maxScore       Int
  levelName      String
  description    String?
  targetDistRate Float?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([orgId, evalYear, gradeName])
  @@unique([orgId, evalYear, gradeOrder])
  @@map("grade_settings")
}

// ============================================
// 3. KPI 도메인
// ============================================

model OrgKpi {
  id           String     @id @default(cuid())
  deptId       String
  department   Department @relation(fields: [deptId], references: [id])
  evalYear     Int
  kpiType      KpiType
  kpiCategory  String
  kpiName      String
  definition   String?
  formula      String?
  targetValue  Float?
  targetValueT Float?
  targetValueE Float?
  targetValueS Float?
  unit         String?
  weight       Float
  difficulty   Difficulty
  status       KpiStatus  @default(DRAFT)
  tags         Json?
  parentOrgKpiId String?
  parentOrgKpi   OrgKpi?    @relation("OrgKpiAlignment", fields: [parentOrgKpiId], references: [id])
  childOrgKpis   OrgKpi[]   @relation("OrgKpiAlignment")
  copiedFromOrgKpiId String?
  copiedFromOrgKpi   OrgKpi?    @relation("OrgKpiCloneSource", fields: [copiedFromOrgKpiId], references: [id])
  clonedOrgKpis      OrgKpi[]   @relation("OrgKpiCloneSource")
  copyMetadata       Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  personalKpis PersonalKpi[]
  adoptedRecommendationItems TeamKpiRecommendationItem[]
  teamKpiReviewItems TeamKpiReviewItem[]

  @@unique([deptId, evalYear, kpiName])
  @@index([evalYear, parentOrgKpiId])
  @@map("org_kpis")
}

model BusinessPlanDocument {
  id          String                 @id @default(cuid())
  deptId      String
  department  Department             @relation(fields: [deptId], references: [id])
  evalYear    Int
  evalCycleId String?
  evalCycle   EvalCycle?             @relation(fields: [evalCycleId], references: [id], onDelete: SetNull)
  title       String
  sourceType  BusinessPlanSourceType @default(TEXT)
  summaryText String?
  bodyText    String
  createdById String
  updatedById String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  recommendationSets TeamKpiRecommendationSet[]
  reviewRuns         TeamKpiReviewRun[]

  @@index([deptId, evalYear, updatedAt])
  @@index([evalCycleId])
  @@map("business_plan_documents")
}

model JobDescriptionDocument {
  id          String               @id @default(cuid())
  deptId      String
  department  Department           @relation(fields: [deptId], references: [id])
  scope       JobDescriptionScope
  evalYear    Int
  evalCycleId String?
  evalCycle   EvalCycle?           @relation(fields: [evalCycleId], references: [id], onDelete: SetNull)
  title       String
  summaryText String?
  bodyText    String
  createdById String
  updatedById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([deptId, scope, evalYear, updatedAt])
  @@index([evalCycleId])
  @@map("job_description_documents")
}

model TeamKpiRecommendationSet {
  id                 String               @id @default(cuid())
  businessPlanId     String?
  businessPlan       BusinessPlanDocument? @relation(fields: [businessPlanId], references: [id], onDelete: SetNull)
  sourceDepartmentId String
  sourceDepartment   Department           @relation("TeamKpiRecommendationSourceDepartment", fields: [sourceDepartmentId], references: [id])
  targetDepartmentId String
  targetDepartment   Department           @relation("TeamKpiRecommendationTargetDepartment", fields: [targetDepartmentId], references: [id])
  evalYear           Int
  evalCycleId        String?
  evalCycle          EvalCycle?           @relation(fields: [evalCycleId], references: [id], onDelete: SetNull)
  requesterId        String
  aiRequestLogId     String?
  summaryText        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  items TeamKpiRecommendationItem[]

  @@index([targetDepartmentId, evalYear, createdAt])
  @@index([businessPlanId])
  @@map("team_kpi_recommendation_sets")
}

model TeamKpiRecommendationItem {
  id                   String                        @id @default(cuid())
  setId                String
  set                  TeamKpiRecommendationSet      @relation(fields: [setId], references: [id], onDelete: Cascade)
  rank                 Int
  recommendationType   TeamKpiRecommendationType     @default(ALIGNED_WITH_DIVISION_KPI)
  title                String
  definition           String?
  formula              String?
  metricSource         String?
  targetValueT         Float?
  targetValueE         Float?
  targetValueS         Float?
  unit                 String?
  weightSuggestion     Float?
  difficultySuggestion Difficulty?
  sourceOrgKpiId       String?
  sourceOrgKpiTitle    String?
  linkageExplanation   String
  recommendationReason String
  whyThisIsHighQuality String?
  basedOnJobDescription Boolean?
  jobDescriptionEvidence String?
  trendRationale       String?
  whyThisFitsTeamRole  String?
  controllabilityNote  String?
  riskComment          String?
  alignmentScore       Float?
  qualityScore         Float?
  difficultyScore      Float?
  recommendedPriority  Int?
  decision             TeamKpiRecommendationDecision @default(PENDING)
  adoptedOrgKpiId      String?
  adoptedOrgKpi        OrgKpi?                       @relation(fields: [adoptedOrgKpiId], references: [id], onDelete: SetNull)
  customizedDraft      Json?
  decidedById          String?
  decidedAt            DateTime?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt

  @@index([setId, rank])
  @@index([adoptedOrgKpiId])
  @@map("team_kpi_recommendation_items")
}

model TeamKpiReviewRun {
  id                 String                @id @default(cuid())
  businessPlanId     String?
  businessPlan       BusinessPlanDocument? @relation(fields: [businessPlanId], references: [id], onDelete: SetNull)
  sourceDepartmentId String?
  sourceDepartment   Department?           @relation("TeamKpiReviewSourceDepartment", fields: [sourceDepartmentId], references: [id], onDelete: SetNull)
  targetDepartmentId String
  targetDepartment   Department            @relation("TeamKpiReviewTargetDepartment", fields: [targetDepartmentId], references: [id])
  evalYear           Int
  evalCycleId        String?
  evalCycle          EvalCycle?            @relation(fields: [evalCycleId], references: [id], onDelete: SetNull)
  requesterId        String
  aiRequestLogId     String?
  reviewType         TeamKpiReviewType     @default(FULL_SET)
  overallVerdict     TeamKpiReviewVerdict?
  overallSummary     String?
  linkedParentCoverage String?
  independentKpiCoverage String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  items TeamKpiReviewItem[]

  @@index([targetDepartmentId, evalYear, createdAt])
  @@index([businessPlanId])
  @@map("team_kpi_review_runs")
}

model TeamKpiReviewItem {
  id                   String               @id @default(cuid())
  runId                String
  run                  TeamKpiReviewRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  orgKpiId             String?
  orgKpi               OrgKpi?              @relation(fields: [orgKpiId], references: [id], onDelete: SetNull)
  recommendationType   TeamKpiRecommendationType?
  reviewType           TeamKpiReviewType    @default(FULL_SET)
  kpiTitleSnapshot     String
  verdict              TeamKpiReviewVerdict
  rationale            String
  linkageComment       String?
  roleFitComment       String?
  measurabilityComment String?
  controllabilityComment String?
  challengeComment     String?
  externalRiskComment  String?
  clarityComment       String?
  duplicationComment   String?
  strongPoint          String?
  weakPoint            String?
  improvementSuggestions String?
  recommendationText   String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([runId])
  @@index([orgKpiId])
  @@map("team_kpi_review_items")
}

model PersonalKpi {
  id             String      @id @default(cuid())
  employeeId     String
  employee       Employee    @relation(fields: [employeeId], references: [id])
  evalYear       Int
  kpiType        KpiType
  kpiName        String
  definition     String?
  formula        String?
  targetValue    Float?
  unit           String?
  weight         Float
  difficulty     Difficulty
  linkedOrgKpiId String?
  linkedOrgKpi   OrgKpi?     @relation(fields: [linkedOrgKpiId], references: [id])
  status         KpiStatus   @default(DRAFT)
  tags           Json?
  copiedFromPersonalKpiId String?
  copiedFromPersonalKpi   PersonalKpi?  @relation("PersonalKpiCloneSource", fields: [copiedFromPersonalKpiId], references: [id])
  clonedPersonalKpis      PersonalKpi[] @relation("PersonalKpiCloneSource")
  copyMetadata            Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  monthlyRecords  MonthlyRecord[]
  evaluationItems EvaluationItem[]

  @@unique([employeeId, evalYear, kpiName])
  @@map("personal_kpis")
}

enum KpiType {
  QUANTITATIVE
  QUALITATIVE
}

enum Difficulty {
  HIGH
  MEDIUM
  LOW
}

enum KpiStatus {
  DRAFT
  CONFIRMED
  ARCHIVED
}

enum BusinessPlanSourceType {
  TEXT
  SUMMARY
}

enum JobDescriptionScope {
  DIVISION
  TEAM
}

enum TeamKpiRecommendationDecision {
  PENDING
  ADOPT_AS_IS
  ADOPT_EDITED
  DISMISSED
  REFERENCED_NEW
}

enum TeamKpiRecommendationType {
  ALIGNED_WITH_DIVISION_KPI
  TEAM_INDEPENDENT
}

enum TeamKpiReviewVerdict {
  ADEQUATE
  CAUTION
  INSUFFICIENT
}

enum TeamKpiReviewType {
  FULL_SET
  ALIGNED_ONLY
  TEAM_INDEPENDENT_ONLY
}

// ============================================
// 4. 월별 실적 입력
// ============================================

model MonthlyRecord {
  id              String      @id @default(cuid())
  personalKpiId   String
  personalKpi     PersonalKpi @relation(fields: [personalKpiId], references: [id])
  employeeId      String
  employee        Employee    @relation(fields: [employeeId], references: [id])
  yearMonth       String
  actualValue     Float?
  achievementRate Float?
  activities      String?
  obstacles       String?
  efforts         String?
  attachments     Json?
  isDraft         Boolean     @default(true)
  submittedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([personalKpiId, yearMonth])
  @@map("monthly_records")
}

// ============================================
// 5. 평가 프로세스
// ============================================

model EvalCycle {
  id              String       @id @default(cuid())
  orgId           String
  organization    Organization @relation(fields: [orgId], references: [id])
  evalYear        Int
  cycleName       String
  status          CycleStatus  @default(SETUP)
  showQuestionWeight Boolean   @default(true)
  showScoreSummary   Boolean   @default(true)
  goalEditMode    GoalEditMode @default(FULL)
  calibrationSessionConfig Json?
  performanceDesignConfig Json?
  kpiSetupStart   DateTime?
  kpiSetupEnd     DateTime?
  selfEvalStart   DateTime?
  selfEvalEnd     DateTime?
  firstEvalStart  DateTime?
  firstEvalEnd    DateTime?
  secondEvalStart DateTime?
  secondEvalEnd   DateTime?
  finalEvalStart  DateTime?
  finalEvalEnd    DateTime?
  ceoAdjustStart  DateTime?
  ceoAdjustEnd    DateTime?
  resultOpenStart DateTime?
  resultOpenEnd   DateTime?
  appealDeadline  DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  evaluations         Evaluation[]
  evaluationAssignments EvaluationAssignment[]
  multiFeedbackRounds MultiFeedbackRound[]
  onboardingReviewWorkflows OnboardingReviewWorkflow[]
  compensationScenarios CompensationScenario[]
  aiCompetencyCycle   AiCompetencyCycle?
  aiCompetencyGateCycle AiCompetencyGateCycle?
  aiCompetencyResults AiCompetencyResult[]
  wordCloud360Cycles  WordCloud360Cycle[]
  businessPlans       BusinessPlanDocument[]
  jobDescriptions     JobDescriptionDocument[]
  teamKpiRecommendationSets TeamKpiRecommendationSet[]
  teamKpiReviewRuns   TeamKpiReviewRun[]

  @@map("eval_cycles")
}

enum CycleStatus {
  SETUP
  KPI_SETTING
  IN_PROGRESS
  SELF_EVAL
  FIRST_EVAL
  SECOND_EVAL
  FINAL_EVAL
  CEO_ADJUST
  RESULT_OPEN
  APPEAL
  CLOSED
}

model CompensationRuleSet {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])
  evalYear     Int
  versionNo    Int
  changeReason String?
  isActive     Boolean      @default(true)
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  rules     CompensationRule[]
  scenarios CompensationScenario[]

  @@unique([orgId, evalYear, versionNo])
  @@map("compensation_rule_sets")
}

model CompensationRule {
  id                 String              @id @default(cuid())
  ruleSetId          String
  ruleSet            CompensationRuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  gradeSettingId     String?
  gradeName          String
  bonusRate          Float
  salaryIncreaseRate Float
  description        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([ruleSetId, gradeName])
  @@map("compensation_rules")
}

model CompensationScenario {
  id                 String                     @id @default(cuid())
  evalCycleId        String
  evalCycle          EvalCycle                  @relation(fields: [evalCycleId], references: [id])
  ruleSetId          String
  ruleSet            CompensationRuleSet        @relation(fields: [ruleSetId], references: [id])
  scenarioName       String
  versionNo          Int
  sourceScenarioId   String?
  sourceScenario     CompensationScenario?      @relation("CompensationScenarioVersion", fields: [sourceScenarioId], references: [id])
  derivedScenarios   CompensationScenario[]     @relation("CompensationScenarioVersion")
  status             CompensationScenarioStatus @default(DRAFT)
  budgetLimit        Float
  totalBonus         Float                      @default(0)
  totalSalaryIncrease Float                     @default(0)
  totalCost          Float                      @default(0)
  isOverBudget       Boolean                    @default(false)
  overBudgetAmount   Float                      @default(0)
  needsRecalculation Boolean                    @default(false)
  isLocked           Boolean                    @default(false)
  lockReason         String?
  lockedAt           DateTime?
  reviewedById       String?
  approvedById       String?
  rejectedById       String?
  publishedAt        DateTime?
  createdById        String
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  employees CompensationScenarioEmployee[]
  approvals CompensationApproval[]

  @@unique([evalCycleId, versionNo])
  @@map("compensation_scenarios")
}

model CompensationScenarioEmployee {
  id                        String               @id @default(cuid())
  scenarioId                String
  scenario                  CompensationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  employeeId                String
  employee                  Employee             @relation(fields: [employeeId], references: [id])
  evaluationId              String?
  gradeName                 String
  currentSalary             Float
  bonusRate                 Float
  salaryIncreaseRate        Float
  bonusAmount               Float
  salaryIncreaseAmount      Float
  projectedSalary           Float
  projectedTotalCompensation Float
  sourceRuleId              String?
  sourceRuleVersionNo       Int
  calculationNote           String?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  @@unique([scenarioId, employeeId])
  @@map("compensation_scenario_employees")
}

model CompensationApproval {
  id         String                     @id @default(cuid())
  scenarioId String
  scenario   CompensationScenario       @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  actorId    String
  actorRole  SystemRole
  action     CompensationApprovalAction
  fromStatus CompensationScenarioStatus
  toStatus   CompensationScenarioStatus
  comment    String?
  createdAt  DateTime                   @default(now())

  @@index([scenarioId, createdAt])
  @@map("compensation_approvals")
}

enum CompensationScenarioStatus {
  DRAFT
  UNDER_REVIEW
  REVIEW_APPROVED
  REJECTED
  FINAL_APPROVED
}

enum CompensationApprovalAction {
  SUBMIT
  REVIEW_APPROVE
  FINAL_APPROVE
  REJECT
  LOCK
  RECALCULATE
}

model Evaluation {
  id              String     @id @default(cuid())
  evalCycleId     String
  evalCycle       EvalCycle  @relation(fields: [evalCycleId], references: [id])
  targetId        String
  target          Employee   @relation("EvalTarget", fields: [targetId], references: [id])
  evaluatorId     String
  evaluator       Employee   @relation("Evaluator", fields: [evaluatorId], references: [id])
  evalStage       EvalStage
  totalScore      Float?
  gradeId         String?
  comment         String?
  strengthComment String?
  improvementComment String?
  nextStepGuidance String?
  status          EvalStatus @default(PENDING)
  isDraft         Boolean    @default(true)
  submittedAt     DateTime?
  isRejected      Boolean    @default(false)
  rejectionReason String?
  rejectedAt      DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  items   EvaluationItem[]
  appeals Appeal[]

  @@unique([evalCycleId, targetId, evalStage])
  @@map("evaluations")
}

enum EvalStage {
  SELF
  FIRST
  SECOND
  FINAL
  CEO_ADJUST
}

enum EvalStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  REJECTED
  CONFIRMED
}

enum EvaluationAssignmentSource {
  AUTO
  MANUAL
}

model EvaluationAssignment {
  id               String                     @id @default(cuid())
  evalCycleId      String
  evalCycle        EvalCycle                  @relation(fields: [evalCycleId], references: [id], onDelete: Cascade)
  targetId         String
  target           Employee                   @relation("PerformanceEvaluationAssignmentTarget", fields: [targetId], references: [id], onDelete: Cascade)
  evalStage        EvalStage
  evaluatorId      String
  evaluator        Employee                   @relation("PerformanceEvaluationAssignmentEvaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)
  assignmentSource EvaluationAssignmentSource @default(AUTO)
  note             String?
  createdById      String?
  createdBy        Employee?                  @relation("PerformanceEvaluationAssignmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById      String?
  updatedBy        Employee?                  @relation("PerformanceEvaluationAssignmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@unique([evalCycleId, targetId, evalStage])
  @@index([evaluatorId, evalCycleId, evalStage])
  @@index([targetId, evalCycleId])
  @@map("evaluation_assignments")
}

model EvaluationItem {
  id            String      @id @default(cuid())
  evaluationId  String
  evaluation    Evaluation  @relation(fields: [evaluationId], references: [id])
  personalKpiId String
  personalKpi   PersonalKpi @relation(fields: [personalKpiId], references: [id])
