{
  "name": "kpi-pms",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
  "dev": "next dev",
  "build": "prisma generate && next build",
  "postinstall": "prisma generate",
  "start": "next start",
  "lint": "eslint",
  "typecheck": "tsc --noEmit",
  "db:generate": "prisma generate",
  "db:migrate": "prisma migrate dev",
  "db:push": "prisma db push",
  "db:seed": "ts-node -P tsconfig.seed.json prisma/seed.ts",
  "db:studio": "prisma studio",
  "db:reset": "prisma migrate reset",
  "register:google-email": "ts-node -P tsconfig.seed.json scripts/register-google-email.ts",
  "test": "npm run test:google-workspace && npm run test:auth && npm run test:ai && npm run test:compensation && npm run test:notifications && npm run test:ops && npm run test:navigation && npm run test:pwa && npm run test:interactions && npm run test:feedback360",
  "test:navigation": "ts-node -P tsconfig.seed.json tests/navigation-integrity.test.ts",
  "test:interactions": "ts-node -P tsconfig.seed.json tests/interaction-integrity.test.ts",
  "test:feedback360": "ts-node -P tsconfig.seed.json tests/feedback-360-foundation.test.ts",
  "test:google-workspace": "ts-node -P tsconfig.seed.json tests/google-workspace.test.ts",
  "test:auth": "ts-node -P tsconfig.seed.json tests/auth-rbac.test.ts && ts-node -P tsconfig.seed.json tests/google-auth-flow.test.ts",
  "test:ai": "ts-node -P tsconfig.seed.json tests/ai.test.ts && ts-node -P tsconfig.seed.json tests/evaluation-ai-assist.test.ts",
  "test:compensation": "ts-node -P tsconfig.seed.json tests/compensation.test.ts",
  "test:notifications": "ts-node -P tsconfig.seed.json tests/notifications.test.ts",
  "test:ops": "ts-node -P tsconfig.seed.json tests/ops.test.ts",
  "test:pwa": "ts-node -P tsconfig.seed.json tests/pwa-cache-safety.test.ts"
},
  "prisma": {
    "seed": "ts-node -P tsconfig.seed.json prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
